# ============================================================
# CRYPTO TRADING AGENT - ENVIRONMENT CONFIGURATION
# ============================================================

# ---- TRADING MODE (CRITICAL) ----
PAPER_TRADING=true
LIVE_TRADING=false
# Set LIVE_TRADING=true ONLY after paper trading validation
# Both can be true during testing, but PAPER wins

# ---- MEXC API (only needed for live trading) ----
MEXC_API_KEY=your_api_key_here
MEXC_API_SECRET=your_api_secret_here
MEXC_BASE_URL=https://contract.mexc.com

# ---- AI AGENT (optional - rule-based works without this) ----
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# ---- RISK CONFIGURATION ----
DEFAULT_RISK_MODE=LOW_RISK
ALLOWED_SYMBOLS=BTC_USDT,ETH_USDT,SOL_USDT

# ---- LOW RISK OVERRIDES (optional) ----
LOW_RISK_MAX_LEVERAGE=2
LOW_RISK_POSITION_SIZE_PCT=0.01
LOW_RISK_CONFIDENCE_THRESHOLD=0.80
LOW_RISK_MAX_POSITIONS=1
LOW_RISK_STOP_LOSS_PCT=0.02
LOW_RISK_TAKE_PROFIT_PCT=0.04

# ---- MID RISK OVERRIDES (optional) ----
MID_RISK_MAX_LEVERAGE=3
MID_RISK_POSITION_SIZE_PCT=0.02
MID_RISK_CONFIDENCE_THRESHOLD=0.65
MID_RISK_MAX_POSITIONS=2
MID_RISK_STOP_LOSS_PCT=0.03
MID_RISK_TAKE_PROFIT_PCT=0.06

# ---- HIGH RISK OVERRIDES (optional) ----
HIGH_RISK_MAX_LEVERAGE=5
HIGH_RISK_POSITION_SIZE_PCT=0.03
HIGH_RISK_CONFIDENCE_THRESHOLD=0.50
HIGH_RISK_MAX_POSITIONS=2
HIGH_RISK_STOP_LOSS_PCT=0.05
HIGH_RISK_TAKE_PROFIT_PCT=0.10

# ---- SAFETY LIMITS ----
MAX_DAILY_LOSS_PCT=0.05
MAX_SPREAD_PCT=0.003
DATA_FRESHNESS_SECONDS=30
COOLDOWN_MINUTES=30
CIRCUIT_BREAKER_ERRORS=5

# ---- AGENT LOOP ----
AGENT_LOOP_INTERVAL_SECONDS=60
MANUAL_APPROVAL_MODE=false

# ---- DATABASE ----
DATABASE_URL=sqlite:///./data/trading.db

# ---- SERVER ----
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ---- LOGGING ----
LOG_LEVEL=INFO
LOG_FILE=logs/trading.log
